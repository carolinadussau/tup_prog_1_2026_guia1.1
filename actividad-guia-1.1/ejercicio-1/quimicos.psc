Proceso Quimicos

    Definir ml, lt, cantA, cantB Como Real;

    Escribir "Ingrese cantidad de mililitros:";
    Leer ml;

    lt <- ml / 1000;

    cantA <- lt * 2.55;
    cantB <- lt * 5.78;

    Escribir "Cantidad de químico A: ", cantA;
    Escribir "Cantidad de químico B: ", cantB;

FinProceso